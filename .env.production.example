# =============================================================================
# Roomora Production Environment Configuration Template
# =============================================================================
# Rename this file to .env.production when setting up variables for a live environment.
# Never commit your active production secrets to the repository.

APP_NAME=Roomora
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://roomora.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

# Production bcrypt rounds (use 12 or higher for better security)
BCRYPT_ROUNDS=12

# Admin Seeder Password (override for DatabaseSeeder in non-production,
# though database seeding should not run in a production environment anyway)
ADMIN_SEED_PASSWORD=

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# Production Database Configuration
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=roomora_production
DB_USERNAME=roomora_db_user
DB_PASSWORD=YOUR_SECURE_DATABASE_PASSWORD

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database

# Production Mailer Configuration (Use smtp, ses, mailgun, postmark, etc.)
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=postmaster@roomora.com
MAIL_PASSWORD=YOUR_SMTP_PASSWORD_HERE
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@roomora.com"
MAIL_FROM_NAME="${APP_NAME}"

# AWS S3 Storage (Required if using Amazon S3 for file uploads in production)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
